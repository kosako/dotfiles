{{- template "require-profile" . -}}
{{- $prof := index .profiles .profile -}}
{{- $caps := index $prof "capabilities" -}}
{{- $profileModules := index $prof "modules" -}}
{{/* Repo-management files are never applied to the home directory.
     chezmoi reads the source directory, not the git index, so even
     gitignored local files must be listed here. */}}
README.md
AGENTS.md
LICENSE
docs
scripts
templates
worklog

{{/* User-local Claude files are never tracked. settings.local.json holds
     dynamic, machine/session-specific permissions that Claude Code writes
     itself; chezmoi must not manage it. settings.json (the shared, public-safe
     subset) is gated via the claude-settings module below. */}}
.claude/settings.local.json

{{/* Module-declared paths (.chezmoidata/modules.yaml) are managed only
     when the profile lists the module and every capability in its
     requires: matches. Everything else is ignored, so a path is only
     applied when a module explicitly claims it. */}}
{{- range $name, $module := .modules }}
{{- if hasKey $module "paths" }}
{{- $enabled := has $name $profileModules }}
{{- if hasKey $module "requires" }}
{{- range $capability, $want := $module.requires }}
{{- if ne (index $caps $capability) $want }}
{{- $enabled = false }}
{{- end }}
{{- end }}
{{- end }}
{{- if not $enabled }}
{{- range $module.paths }}
{{ . }}
{{- end }}
{{- end }}
{{- end }}
{{- end }}
